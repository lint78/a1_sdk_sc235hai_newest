diff --git a/arch/arm/mach-smartsens/smartsens.c b/arch/arm/mach-smartsens/smartsens.c
new file mode 100644
index 000000000..953c96d70
--- /dev/null
+++ b/arch/arm/mach-smartsens/smartsens.c
@@ -0,0 +1,32 @@
+// SPDX-License-Identifier: GPL-2.0-or-later
+/*
+ * Device Tree support for Smartsens SoCs.
+ *
+ * Copyright (C) 2024 Smartsens Inc.
+ */
+#include <linux/init.h>
+#include <linux/io.h>
+#include <linux/of_platform.h>
+#include <asm/mach/arch.h>
+
+#define KERNEL_BOOT_STATUS_REG		0xb10032fd
+#define KERNEL_BOOT_READY_MAGIC		0x54
+
+static void __init smartsens_dt_init(void)
+{
+	void __iomem *kernel_boot_reg = ioremap(KERNEL_BOOT_STATUS_REG, 0x1);
+	writeb(KERNEL_BOOT_READY_MAGIC, kernel_boot_reg);
+	iounmap(kernel_boot_reg);
+}
+
+static const char *const smartsens_m1_dt_compat[] __initconst = {
+	"smartsens,m1-fpga",
+	"smartsens,m1-evb",
+	NULL,
+};
+
+DT_MACHINE_START(SMARTSENS, "Smartsens M1 SoC (Device Tree)")
+	.init_machine	= smartsens_dt_init,
+	.dt_compat	    = smartsens_m1_dt_compat,
+MACHINE_END
+
