+				partition@0 {
+					label = "bootloader";
+					reg = <0x00500000 0x100000>;
+				};
+				partition@1 {
+					label = "kernel";
+					reg = <0x00600000 0x100000>;
+				};
+				partition@2 {
+					label = "rootfs";
+					reg = <0x00800000 0x100000>;
+				};
+			};
+		};
+	};*/
+
+};
diff --git a/arch/arm/include/debug/smarts1.S b/arch/arm/include/debug/smarts1.S
new file mode 100644
index 000000000..fce9bf625
--- /dev/null
+++ b/arch/arm/include/debug/smarts1.S
@@ -0,0 +1,43 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * Debugging macro include header for Smartsens S1 UART
+ *
+ * Copyright (C) 2022 Smartsens Innovation Ltd.
+*/
+
+#define SMARTS1_UART_BASE_PHYS 0xb1002280
+#define TX_DATA_OFF 0x58
+#define TX_FIFO_CNT_OFF 0x60
+
+		.macro	addruart, rp, rv, tmp
+		ldr	\rp, =SMARTS1_UART_BASE_PHYS
+		ldr	\rv, =0xf0002280
+		.endm
+
+		.macro	senduart,rd,rx
+		strb	\rd, [\rx, #TX_DATA_OFF]
+		.endm
+
+		.macro	waituartcts,rd,rx
+		.endm
+
+		.macro	waituarttxrdy,rd,rx
+#if 0
+1000:		ldr	\rd, [\rx, #TX_FIFO_CNT_OFF]
+		cmp	\rd, #0
+		beq	1000b
+#endif
+		.endm
+
+	.macro	busyuart,rd,rx
+#if 1
+1001:		ldr	\rd, [\rx, #TX_FIFO_CNT_OFF]
+		tst	\rd, #20
+		beq	1001b
+#else
+1001:		ldr	\rd, [\rx, #TX_FIFO_CNT_OFF]
+		cmp	\rd, #10
+		bls	1001b
+		//beq	1001b
+#endif
+		.endm
