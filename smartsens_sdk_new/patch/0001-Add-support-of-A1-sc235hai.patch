+/ {
+	#address-cells = <1>;
+	#size-cells = <1>;
+
+	model = "SmartSens M-Serial Family Soc";
+	compatible = "smartsens,m1";
+	interrupt-parent = <&gic>;
+
+	aliases {
+		serial0 = &uart0;
+	};
+	timer {
+			compatible = "arm,armv7-timer";
+			interrupts = <GIC_PPI 13 (GIC_CPU_MASK_SIMPLE(1) | IRQ_TYPE_LEVEL_HIGH)>,
