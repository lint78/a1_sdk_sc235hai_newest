+
+
+#define SMARTS1_VAL_MODIFY_FIELD(val, start_bit, end_bit, field_val) \
+    do { \
+        /* clear field bits */ \
+        val &= ~((masks[end_bit - start_bit]) << start_bit); \
+        /* set field bits */ \
+        val |= ((field_val & masks[end_bit - start_bit]) << start_bit); \
+    } while(0);
+
+static u32 masks[32] = {
+    0x1, 0x3, 0x7, 0xf,
+    0x1f, 0x3f, 0x7f, 0xff,
+    0x1ff, 0x3ff, 0x7ff, 0xfff,
+    0x1fff, 0x3fff, 0x7fff, 0xffff,
+    0x1ffff, 0x3ffff, 0x7ffff, 0xfffff,
+    0x1fffff, 0x3fffff, 0x7fffff, 0xffffff,
+    0x1ffffff, 0x3ffffff, 0x7ffffff, 0xfffffff,
+    0x1fffffff, 0x3fffffff, 0x7fffffff, 0xffffffff
+};
+
+static struct uart_driver smarts1_uart_driver;
+
+struct smarts1_uart_port {
+	struct uart_port port;
+	u32 baud;
+};
+
+#define to_smarts1_uart_port(port) container_of(port, struct smarts1_uart_port, port)
+
+static struct smarts1_uart_port *smarts1_uart_ports[SMARTS1_UART_PORT_NUM];
+
+static inline void smarts1_uart_write(struct uart_port *port, u32 val,
+				  unsigned int off)
+{
+	writel(val, port->membase + off);
+}
+
+static inline u32 smarts1_uart_read(struct uart_port *port, unsigned int off)
+{
+	return readl(port->membase + off);
+}
+
+static unsigned int smarts1_uart_tx_empty(struct uart_port *port)
+{
+	u32 val;
+
+	val = smarts1_uart_read(port, SMARTS1_REG_TX_FIFO_FREE_CNT_OFFSET);
+	return val ? TIOCSER_TEMT : 0;
+}
+
+static unsigned int smarts1_uart_get_mctrl(struct uart_port *port)
+{
+	return 0;
+}
+
+static void smarts1_uart_set_mctrl(struct uart_port *port, unsigned int mctrl)
+{
+
+}
+
+static void smarts1_uart_stop_tx(struct uart_port *port)
+{
+	u32 val;
+
+    /* disable tx interrupt */
+	val = smarts1_uart_read(port, SMARTS1_REG_TX_IRQ_EN_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 0, 1, 0x0);
+	smarts1_uart_write(port, val, SMARTS1_REG_TX_IRQ_EN_OFFSET);
+    /* clear tx irq status if had */
+	val = smarts1_uart_read(port, SMARTS1_REG_TX_IRQ_CLR_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 0, 1, 0x0);
+	smarts1_uart_write(port, val, SMARTS1_REG_TX_IRQ_CLR_OFFSET);
+
+	/* disable tx, disable tx parity */
+	val = smarts1_uart_read(port, SMARTS1_REG_TX_CTRL_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 0, 2, 0x0);
+	smarts1_uart_write(port, val, SMARTS1_REG_TX_CTRL_OFFSET);
+}
+
+static void smarts1_uart_stop_rx(struct uart_port *port)
+{
+	u32 val;
+
+	/* disable rx err interrupts */
+	smarts1_uart_write(port, 0, SMARTS1_REG_RX_IRQ_EN_OFFSET);
+
+	/* disable rx interrupt */
+	val = smarts1_uart_read(port, SMARTS1_REG_RX_CTRL_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 16, 16, 0x0); /* rx enable */
+	SMARTS1_VAL_MODIFY_FIELD(val,  8, 13, 0x0); /* rx threshold, set non 0 to enalbe rx interrupt */
+	SMARTS1_VAL_MODIFY_FIELD(val,  0, 7, 0x0); /* rx timeout */
+	smarts1_uart_write(port, val, SMARTS1_REG_RX_CTRL_OFFSET);
+}
+
+static void smarts1_putchar(struct uart_port *port, int ch)
+{
+   /*  if (!port->membase) */
+		/* return; */
+
+	while (!(smarts1_uart_read(port, SMARTS1_REG_TX_FIFO_FREE_CNT_OFFSET)))
+		cpu_relax();
+
+	//smarts1_uart_write(port, ch, SMARTS1_REG_TX_DATA_OFFSET);
+	writeb(ch, port->membase + SMARTS1_REG_TX_DATA_OFFSET);
+}
+
+static void smarts1_uart_start_tx(struct uart_port *port)
+{
+	struct circ_buf *xmit = &port->state->xmit;
+	unsigned char ch;
+
+	if (unlikely(port->x_char)) {
+		writeb(port->x_char, port->membase + SMARTS1_REG_TX_DATA_OFFSET);
+		port->icount.tx++;
+		port->x_char = 0;
+	} else if (!uart_circ_empty(xmit)) {
+		while (xmit->head != xmit->tail) {
+			ch = xmit->buf[xmit->tail];
+			xmit->tail = (xmit->tail + 1) & (UART_XMIT_SIZE - 1);
+			port->icount.tx++;
+			smarts1_putchar(port, ch);
+#if 0
+			while (!(smarts1_uart_read(port, SMARTS1_REG_TX_FIFO_FREE_CNT_OFFSET)))
+				cpu_relax();
+			smarts1_uart_write(port, ch, SMARTS1_REG_TX_DATA_OFFSET);
+#endif
+		}
+	}
+
+	if (uart_circ_chars_pending(xmit) < WAKEUP_CHARS)
+		uart_write_wakeup(port);
+}
