+	ctrl &= ~SMARTS1_UART_DMA_EN;
+
+	triggers  = (SMARTS1_UART_AFC_LEVEL(20) | SMARTS1_UART_RX_TRIGGER(16));
+	irq_mask = smarts1_uart_read(port, SMARTS1_UART_IRQ_MASK);
+	smarts1_uart_write(port, 0, SMARTS1_UART_IRQ_MASK);
+
+	smarts1_uart_write(port, triggers, SMARTS1_UART_IRQ_TRIGGERS);
+	smarts1_uart_write(port, ctrl, SMARTS1_UART_CTRL);
+	smarts1_uart_write(port, cmd_set, SMARTS1_UART_CMD_SET);
+	smarts1_uart_write(port, cmd_clr, SMARTS1_UART_CMD_CLR);
+
+	smarts1_uart_write(port, irq_mask, SMARTS1_UART_IRQ_MASK);
+
+	/* Don't rewrite B0 */
+	if (tty_termios_baud_rate(termios))
+		tty_termios_encode_baud_rate(termios, baud, baud);
+
+	/* update the per-port timeout */
+	uart_update_timeout(port, termios->c_cflag, baud);
+
+	spin_unlock_irqrestore(&port->lock, flags);
+#endif
+}
+
