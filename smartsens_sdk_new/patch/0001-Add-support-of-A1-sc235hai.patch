+			clock-frequency = <12000000>;
+	};
+	cpus {
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		cpu0: cpu@0 {
+			device_type = "cpu";
+			compatible = "arm,cortex-a7";
+			reg = <0x0>;
+		};
+	};
+
+	gic: interrupt-controller@e0000000 {
+		compatible = "arm,gic-400";
+		interrupt-controller;
+		#interrupt-cells = <3>;
+		#address-cells = <0>;
+
+		reg = <0xe0001000 0x1000>,
+		      <0xe0002000 0x2000>;
+		interrupts = <GIC_PPI 9 (GIC_CPU_MASK_SIMPLE(1) | IRQ_TYPE_LEVEL_HIGH)>;
+	};
+
+	sram: sram@10040000 {
+		compatible = "mmio-sram";
+		reg = <0x10040000 0x000cb000>; /* 768+300-128=940K */
+		#address-cells = <1>;
+		#size-cells = <1>;
+		ranges = <0 0x10040000 0x000cb000>;
+		npu_sram: sram@0 {
+			reg = <0x0 0x000cb000>;
+			pool;
+		};
+	};
+
+	ocm {
+		compatible = "smartsens,on-chip-memory";
+		iram = <&npu_sram>;
+	};
+
+	uart0: uart@b1002280 {
+		compatible = "smartsens,s1-uart";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1002280 0x100>;
+		interrupts = <GIC_SPI 16 IRQ_TYPE_LEVEL_HIGH>;
+		clock-frequency = <25000000>;
+		status = "disabled";
+	};
+	
+	axi_dma: axi_dma@b1003700 {
+		compatible = "smartsens,axidma";
+		reg = <0xb1003700 0x100>;
+		interrupts = <GIC_SPI 28 IRQ_TYPE_EDGE_RISING>;
+		status = "okay";
+	};
+
+	cmdset: cmdset@b1002300 {
+		compatible = "smartsens,cmdset";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1002300 0x20>;
+		/* interrupts = <GIC_SPI 0 IRQ_TYPE_LEVEL_HIGH>; */
+		status = "okay";
+	};
+
+	aec: aec@b1007800 {
+		compatible = "smartsens,aec";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1007800  0x100>;
+		status = "okay";
+	};
+
+	osd: osd@b1009400 {
+		compatible = "smartsens, s1-osd";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1009400  0x100>;
+		interrupts = <GIC_SPI 15 IRQ_TYPE_LEVEL_HIGH>;
+		status = "okay";
+	};
+
+	isp_debug: isp_debug@b1009500 {
+		compatible = "smartsens, s1-isp_debug";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1009500  0x100>;
+		interrupts = <GIC_SPI 15 IRQ_TYPE_LEVEL_HIGH>;
+		status = "okay";
+	};
+
+	preonpipe: preonpipe@b1004000 {
+		compatible = "smartsens,ai-pre-online";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1004000 0x100>,
+		      <0xb1008000 0x130>;
+		interrupts = <GIC_SPI 0 IRQ_TYPE_EDGE_RISING>,//save2 sof interrupt sensor 0
+			     <GIC_SPI 4 IRQ_TYPE_EDGE_RISING>,//save2 sof interrupt sensor 1
+		             <GIC_SPI 2 IRQ_TYPE_EDGE_RISING>,//save3 sof interrupt sensor 0
+			     <GIC_SPI 6 IRQ_TYPE_EDGE_RISING>,//save3 sof interrupt sensor 1
+			     <GIC_SPI 1 IRQ_TYPE_EDGE_RISING>,//save2 eof interrupt sensor 0
+			     <GIC_SPI 5 IRQ_TYPE_EDGE_RISING>,//save2 eof interrupt sensor 1
+			     <GIC_SPI 3 IRQ_TYPE_EDGE_RISING>,//save3 eof interrupt sensor 0
+			     <GIC_SPI 7 IRQ_TYPE_EDGE_RISING>,//save3 eof interrupt sensor 1
+			     <GIC_SPI 12 IRQ_TYPE_EDGE_RISING>,
+			     <GIC_SPI 13 IRQ_TYPE_EDGE_RISING>;
+		status = "okay";
+	};
+
+	preoffpipe: preoffpipe@b100a000 {
+		compatible = "smartsens,ai-pre-offline";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb100a000 0x300>;
+		interrupts = <GIC_SPI 9 IRQ_TYPE_EDGE_RISING>;
+		status = "okay";
+	};
+
+	lnpu: lnpu@b100c000 {
+		compatible = "smartsens,s1-lnpu";
+		reg = <0xb100c000 0x4000>;
+		fpga_freq = <2500000>;
+		prof_base = <0xb10a0000>;
+		prof_size = <0x10000>;
+		sram_base = <0x10040000>;
+		sram_size = <0x000cb000>;
+		interrupts = <GIC_SPI 14 IRQ_TYPE_LEVEL_HIGH>;
+		status = "okay";
+	};
+	
+	emb: emb@b1087000{
+		compatible = "smartsens,s1-emb";
+		#address-cells = <1>;
+		#size-cells = <1>;
+		reg = <0xb1087000  0xfff>,
+				<0xb1003800 0xff>;
+		interrupts = <GIC_SPI 12 IRQ_TYPE_EDGE_RISING>, // isp sof
+			     <GIC_SPI 13 IRQ_TYPE_EDGE_RISING>;// isp sof
+		status = "okay";
+	};
+
+/*	&spi0 {
