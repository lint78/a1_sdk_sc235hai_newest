diff --git a/drivers/spi/spi-smarts1-qspi.c b/drivers/spi/spi-smarts1-qspi.c
new file mode 100644
index 000000000..f454b27d5
--- /dev/null
+++ b/drivers/spi/spi-smarts1-qspi.c
@@ -0,0 +1,769 @@
+/*
+ * Author: Primo Wu <Xinyu.Wu@Smartsens.com>
+ */
+
+#include <linux/clk.h>
+#include <linux/delay.h>
+#include <linux/interrupt.h>
+#include <linux/io.h>
+#include <linux/module.h>
+#include <linux/of_irq.h>
+#include <linux/of_address.h>
+#include <linux/platform_device.h>
+#include <linux/spi/spi.h>
+#include <linux/workqueue.h>
+#include <linux/spi/spi-mem.h>
+
+/* Register offset definitions */
+#define SS_QSPI_GLBCFG_OFFSET		0x00  	//RW
+#define SS_QSPI_MODE_OFFSET			0x04	//RW
+#define SS_QSPI_INT_OFFSET			0x08	//RW
+#define SS_QSPI_TX_FREE_OFFSET		0x0c	//RO
+#define SS_QSPI_RX_FREE_OFFSET		0x10	//RO
+#define SS_QSPI_STS_OFFSET			0x14	//RO
+#define SS_QSPI_CLR_OFFSET			0x18	//WO
+#define SS_QSPI_RX_DATA_OFFSET		0x1c	//RO
+#define SS_QSPI_TX_DATA_OFFSET		0x20	//WO
+#define SS_QSPI_XIPCFG_OFFSET		0x24	//RW
+#define SS_QSPI_RXLEN_OFFSET		0x28	//RW
+#define SS_QSPI_TXLEN_OFFSET		0x2c	//RW
+#define SS_QSPI_TRANS_CTL_OFFSET	0x30	//WO
+
+/* QSPI Configuration Register bit Mask */
+#define SS_QSPI_GLBCFG_EN_MASK			BIT(0)
+#define SS_QSPI_GLBCFG_CPOL_MASK		BIT(1)
+#define SS_QSPI_GLBCFG_BIT_ORDER_MASK	BIT(4)
+#define SS_QSPI_GLBCFG_IO_ORDER_MASK	BIT(5)
+#define SS_QSPI_GLBCFG_S_DELAY_MASK		GENMASK(11, 8)
+#define SS_QSPI_GLBCFG_S_DELAY_SHIFT	8
+#define SS_QSPI_GLBCFG_E_DELAY_MASK		GENMASK(15, 12)
+#define SS_QSPI_GLBCFG_E_DELAY_SHIFT	12
+
+/* QSPI Mode Register bit Mask */
+#define SS_QSPI_MODE_DDR_EN_MASK			BIT(0)
+#define SS_QSPI_MODE_PROTO_MASK				GENMASK(2,1)
+#define SS_QSPI_MODE_PROTO_SHIFT			1
+#define SS_QSPI_MODE_TRANS_MASK				GENMASK(4,3)
+#define SS_QSPI_MODE_TRANS_SHIFT			3
+#define SS_QSPI_MODE_CS_MASK				GENMASK(11,8)
+#define SS_QSPI_MODE_CS_SHIFT				8
+
+/* QSPI FIFO Interrupt Register bit Mask */
+#define SS_QSPI_INT_TXEN_MASK				BIT(0)
+#define SS_QSPI_INT_TXTHRSD_MASK			GENMASK(6,1)
+#define SS_QSPI_INT_TXTHRSD_SHIFT			1
+#define SS_QSPI_INT_RXEN_MASK				BIT(8)
+#define SS_QSPI_INT_RXTHRSD_MASK			GENMASK(14,9)
+#define SS_QSPI_INT_RXTHRSD_SHIFT			9
+
+/* QSPI FIFO TX free Count Register bit Mask */
+#define SS_QSPI_TX_FREE_MASK				GENMASK(5,0)
+
+/* QSPI FIFO RX free Count Register bit Mask */
+#define SS_QSPI_RX_FREE_MASK				GENMASK(5,0)
+
+/* QSPI FIFO Status Register bit Mask */
+#define SS_QSPI_FIFO_STS_TX_INT_MASK			BIT(0)
+#define SS_QSPI_FIFO_STS_TXOF_MASK				BIT(1)
+#define SS_QSPI_FIFO_STS_RX_INT_MASK			BIT(2)
+#define SS_QSPI_FIFO_STS_RXOF_MASK				BIT(3)
+#define SS_QSPI_FIFO_STS_RXUF_MASK				BIT(4)
+
+/* QSPI Clear data  Register bit Mask */
+#define SS_QSPI_CLR_FIFO_MASK			BIT(0)
+#define SS_QSPI_CLR_STS_MASK			BIT(1)
+
+/* QSPI XIP Configure Register bit Mask */
+#define SS_QSPI_XIPCFG_EN_MASK				BIT(0)
+#define SS_QSPI_XIPCFG_RXEN_MASK			BIT(1)
+#define SS_QSPI_XIPCFG_DUMMYS_MASK			GENMASK(7,2)
+#define SS_QSPI_XIPCFG_DUMMYS_SHIFT			2
+#define SS_QSPI_XIPCFG_CMD_MASK				GENMASK(15,8)
+#define SS_QSPI_XIPCFG_CMD_SHIFT			8
+#define SS_QSPI_XIPCFG_PARAL_MASK			BIT(16)
+#define SS_QSPI_XIPCFG_ADDR_ENDI_MASK		BIT(17)
+#define SS_QSPI_XIPCFG_DATA_ENDI_MASK		BIT(18)
+#define SS_QSPI_XIPCFG_ADDR_LEN_MASK		GENMASK(26,24)
+#define SS_QSPI_XIPCFG_ADDR_LEN_SHIFT		24
+
+/* QSPI Transport Control Register bit Mask */
+#define SS_QSPI_TRANS_CTL_DONE_MASK			BIT(0)
+#define SS_QSPI_TRANS_CTL_SUSPEND_MASK		BIT(8)
+#define SS_QSPI_TRANS_CTL_RESTART_MASK		BIT(16)
+
+/* QSPI RX length Register bit Mask */
+#define SS_QSPI_SINLE_LEN_MASK				GENMASK(7,0)
+#define SS_QSPI_RXLEN_MASK					GENMASK(15,8)
+#define SS_QSPI_RXLEN_SHIFT					8
+
+
+/* default data */
+#define DEFAULT_CS_NUM			1 
+#define DEFAULT_DELAY_CYCLES	3 
+#define DEFAULT_FIFO_DEPTH	 	32
+#define DEFAULT_TX_THRESHOLD 		31
+#define DEFAULT_RX_THRESHOLD   		31
+
+#define SS_QSPI_MAX_CS_NUM		1 
+#define SS_QSPI_MAX_CLK  		20000000 
+
+#define TRANS_MODE_DUPLEX 	 		0
+#define TRANS_MODE_TX_ONLY 	 		1
+#define TRANS_MODE_RX_ONLY 	 		2
+
+#define PROTO_MODE_STAND 	 		0
+#define PROTO_MODE_DUAL 	 		1
+#define PROTO_MODE_QUAD 	 		2
+
+typedef enum 
+{
+	TRANS_CTL_RESTART = 0,
+	TRANS_CTL_DONE ,
+}TRANS_CTL_;
+
+
+/**
+ * struct ss_qspi - Defines qspi driver instance
+ * @dev:		Pointer to the this device's information
+ * @regs:		Virtual address of the QSPI controller registers
+ * @refclk:		Pointer to the peripheral clock
+ * @pclk:		Pointer to the APB clock
+ * @irq:		IRQ number
+ * @txbuf:		Pointer to the TX buffer
+ * @rxbuf:		Pointer to the RX buffer
+ * @tx_bytes:		Number of bytes left to transfer
+ * @rx_bytes:		Number of bytes left to receive
+ * @data_completion:	completion structure
+ */
+struct smartsens_qspi {
+	struct device *dev;
+	void __iomem *regs;
+	struct clk *pclk;
+	int tx_irq;
+	int rx_irq;
+	u8 *txbuf;
+	u8 *rxbuf;
+	int tx_bytes;
+	int rx_bytes;
+	struct completion data_completion;
+};
+
+/*
+ * Inline functions for the QSPI controller read/write
+ */
+static inline u32 ss_qspi_read(struct smartsens_qspi *ss_qspi, u32 offset)
+{
+	return readl_relaxed(ss_qspi->regs + offset);
+}
+
+static inline void ss_qspi_write(struct smartsens_qspi *ss_qspi, u32 offset, 
+					u32 val)
+{
+	writel_relaxed(val, ss_qspi->regs + offset);
+}
+
+/**
+ * ss_qspi_init_hw - Initialize the hardware
+ * @ss_qspi:	Pointer to the ss_qspi structure
+ *
+ * The default settings of the QSPI controller's configurable parameters on
+ * reset are
+ *  - Cleart the TX & RX FIFO
+ *  - Cleart the FIFO status signals
+ *	- Enable the QSPI controller
+ */
+static void ss_qspi_init_hw(struct smartsens_qspi *ss_qspi,unsigned int num_cs)
+{
+	u32 config_reg = 0 ;
+
+	ss_qspi_write(ss_qspi, SS_QSPI_GLBCFG_OFFSET, 0);/* clear & stop spi */
+	ss_qspi_write(ss_qspi, SS_QSPI_INT_OFFSET, 0); /* clear & stop interrupt*/
+
+	/** 
+	 *	- Start delay cycles set to 3 
+	 *  - End   delay cycles set to 3 
+	 *  - BIT order set to MSB(0) 
+	 *  - IO line order set to LSB(1)       
+	 *  - CPOL set to level high(1) 
+	 */
+	ss_qspi_write(ss_qspi, SS_QSPI_GLBCFG_OFFSET, 
+		DEFAULT_DELAY_CYCLES << SS_QSPI_GLBCFG_S_DELAY_SHIFT |
+		DEFAULT_DELAY_CYCLES << SS_QSPI_GLBCFG_E_DELAY_SHIFT |
+		~SS_QSPI_GLBCFG_BIT_ORDER_MASK | SS_QSPI_GLBCFG_IO_ORDER_MASK | 
+		SS_QSPI_GLBCFG_CPOL_MASK );
+
+	/** 
+	 *  - CS select  set to 1 
+	 *	- Trans mode set to RX_ONLY (2)
+	 *  - Proto mode set to QUAD	(2)
+	 *  - double rate set to disable(0)
+	 */
+	ss_qspi_write(ss_qspi, SS_QSPI_MODE_OFFSET, 0);/* clear */
+	ss_qspi_write(ss_qspi, 
+		SS_QSPI_MODE_OFFSET, DEFAULT_CS_NUM << SS_QSPI_MODE_CS_SHIFT |
+		TRANS_MODE_RX_ONLY << SS_QSPI_MODE_TRANS_SHIFT |
+		PROTO_MODE_QUAD << SS_QSPI_MODE_PROTO_SHIFT |
+		~SS_QSPI_MODE_DDR_EN_MASK );
+
+	/** 
+	 *	- RX FIFO fhreshold set to default
+	 *  - RX FIFO irq enable 
+	 *	- TX FIFO fhreshold set to default
+	 *  - TX FIFO irq enable   
+	 */
+	ss_qspi_write(ss_qspi, SS_QSPI_INT_OFFSET,
+		DEFAULT_RX_THRESHOLD << SS_QSPI_INT_RXTHRSD_SHIFT |
+		DEFAULT_TX_THRESHOLD << SS_QSPI_INT_TXTHRSD_SHIFT |
+		SS_QSPI_INT_RXEN_MASK | SS_QSPI_INT_TXEN_MASK);
+
+	/* Clear RX & TX FIFO */
+	ss_qspi_write(ss_qspi, SS_QSPI_CLR_OFFSET, SS_QSPI_CLR_FIFO_MASK);
+	/* Clear all status signals */
+	ss_qspi_write(ss_qspi, SS_QSPI_CLR_OFFSET, SS_QSPI_CLR_STS_MASK);
+
+	/** 
+	 *  - TX single wire len set to 4 byte     
+	 */
+	ss_qspi_write(ss_qspi, SS_QSPI_TXLEN_OFFSET, 0); /* clear */
+	ss_qspi_write(ss_qspi, SS_QSPI_TXLEN_OFFSET, 4);
+
+	/* Set qspi enbale */
+	config_reg = ss_qspi_read(ss_qspi, SS_QSPI_GLBCFG_OFFSET);
+	config_reg |= SS_QSPI_GLBCFG_EN_MASK;
+	ss_qspi_write(ss_qspi, SS_QSPI_GLBCFG_OFFSET, config_reg);
+}
+
+
+static bool ss_qspi_supports_op(struct spi_mem *mem,
+				  const struct spi_mem_op *op)
+{
+	if (!spi_mem_default_supports_op(mem, op))
+		return false;
+	/* flash only 3 byte addr */
+	if (op->addr.nbytes > 3){
+		printk("ops addr bytes > 3 byte ,not supported\n");
+		return false;
+	}
+	return true;
+}
+
+/* qspi ip automatically set cs  */
+// static void ss_qspi_chipselect(struct spi_device *spi, bool assert)
+
+static int ss_qspi_config_op(struct smartsens_qspi *ss_qspi, struct spi_device *spi)
+{
+	u32 config_reg = 0;
+
+	config_reg = ss_qspi_read(ss_qspi, SS_QSPI_GLBCFG_OFFSET);
+	
+	/* s1 qspi ip can not support configuration of CPHA  */
+	// if (spi->mode & SPI_CPHA)
+	// 	config_reg |= SS_QSPI_CONFIG_CPHA_MASK;
+
+	/* Set the QSPI clock polarity */
+	if (spi->mode & SPI_CPOL)
+		config_reg |= SS_QSPI_GLBCFG_CPOL_MASK;
+
+	ss_qspi_write(ss_qspi, SS_QSPI_GLBCFG_OFFSET, config_reg);
+
+	return 0;
+}
+
+/**
+ * ss_qspi_setup_op - Configure the QSPI controller
+ * @spi:	Pointer to the spi_device structure
+ * Return:	0 on success and error value on failure
+ */
+static int ss_qspi_setup_op(struct spi_device *spi)
+{
+	struct spi_controller *ctlr = spi->master;
+	struct smartsens_qspi *qspi = spi_controller_get_devdata(ctlr);
+	
+	u32 config_reg = 0 ;
+
+	if (ctlr->busy)
+		return -EBUSY;
+
+	/* set qspi setup */
+	config_reg = ss_qspi_read(qspi, SS_QSPI_GLBCFG_OFFSET);
+	config_reg |= SS_QSPI_GLBCFG_EN_MASK;
+	ss_qspi_write(qspi, SS_QSPI_GLBCFG_OFFSET, config_reg);
+	return 0;
+}
+
+/**
+ * @brief 		- Config spi suspend resart
+ * 
+ * @param spi 	- Pointer to the spi_device structure
+ * @param cmd   - Trans cmd : restart / done 
+ * @return int  - 0 on success and error value on failure
+ */
+static int ss_qspi_trans_ctl(struct spi_device *spi, TRANS_CTL_ cmd)
+{
+	struct spi_controller *ctlr = spi->master;
+	struct smartsens_qspi *qspi = spi_controller_get_devdata(ctlr);
+	
+	u32 config_reg = 0 ;
+
+	switch (cmd)
+	{
+	case TRANS_CTL_RESTART:
+		config_reg = ss_qspi_write(qspi, SS_QSPI_TRANS_CTL_OFFSET);
+		config_reg |= SS_QSPI_TRANS_CTL_RESTART_MASK; 
+		ss_qspi_write(qspi, SS_QSPI_TRANS_CTL_OFFSET , config_reg);
+		break;
+
+	case TRANS_CTL_DONE:
+		config_reg = ss_qspi_write(qspi, SS_QSPI_TRANS_CTL_OFFSET);
+		config_reg |= SS_QSPI_TRANS_CTL_DONE_MASK; 
+		ss_qspi_write(qspi, SS_QSPI_TRANS_CTL_OFFSET , config_reg);
+		break;
+
+	default:
+		break;
+	}
+	return  0;
+}
+
+/**
+ * @brief 		- Config tx&rx threshold len &  trans_len
+ * 
+ * @param spi 	- Pointer to the spi_device structure
+ * @param len   - Transport lenght
+ * @param is_tx - is tx dirction 
+ * @return int 
+ */
+static int ss_qspi_set_trans_lens(struct spi_device *spi, int len, bool is_tx)
+{
+	struct spi_controller *ctlr = spi->master;
+	struct smartsens_qspi *qspi = spi_controller_get_devdata(ctlr);
+	
+	u32 config_reg = 0 ;
+
+	config_reg = ss_qspi_read(qspi, SS_QSPI_INT_OFFSET);
+
+	if(is_tx){
+		if( len != (config_reg & SS_QSPI_INT_TXTHRSD_MASK) ){
+			/* set tx threshold to len  */
+			config_reg &= ~(SS_QSPI_INT_TXEN_MASK | SS_QSPI_INT_TXTHRSD_MASK);
+			config_reg |= (len << SS_QSPI_INT_TXTHRSD_SHIFT);
+			ss_qspi_write(qspi, SS_QSPI_INT_OFFSET , config_reg);
+			/* set tx bytes to len  , for auto suspend*/
+			ss_qspi_write(qspi, SS_QSPI_TXLEN_OFFSET , len);	
+		}
+	}else{
+		if( len != (config_reg & SS_QSPI_INT_RXTHRSD_MASK) ){
+			/* set rx threshold to len  */
+			config_reg &= ~(SS_QSPI_INT_RXEN_MASK | SS_QSPI_INT_RXTHRSD_MASK);
+			config_reg |= (len << SS_QSPI_INT_RXTHRSD_SHIFT);
+			ss_qspi_write(qspi, SS_QSPI_INT_OFFSET , config_reg);
+			/* set tx bytes to len , for auto suspend */
+			config_reg = ss_qspi_read(qspi, SS_QSPI_RXLEN_OFFSET);
+			config_reg &= ~(SS_QSPI_RXLEN_MASK);
+			config_reg |= (len << SS_QSPI_RXLEN_SHIFT);
+			ss_qspi_write(qspi, SS_QSPI_RXLEN_OFFSET , config_reg);
+		}
+	}
+	return  0;
+}
+
+static int ss_qspi_intr_switch(struct spi_device *spi, bool is_tx, bool is_open)
+{
+	struct spi_controller *ctlr = spi->master;
+	struct smartsens_qspi *qspi = spi_controller_get_devdata(ctlr);
+	
+	u32 config_reg = 0 ;
+
+	config_reg = ss_qspi_read(qspi, SS_QSPI_INT_OFFSET);
+
+	if(is_tx){
+		if(is_open)
+			config_reg |= SS_QSPI_INT_TXEN_MASK;
+		else
+			config_reg |= ~SS_QSPI_INT_TXEN_MASK;
+		ss_qspi_write(qspi, SS_QSPI_INT_OFFSET , config_reg);
+	}
+	else{
+		if(is_open)
+			config_reg |= SS_QSPI_INT_RXEN_MASK;
+		else
+			config_reg |= ~SS_QSPI_INT_RXEN_MASK;
+		ss_qspi_write(qspi, SS_QSPI_INT_OFFSET , config_reg);
+	}
+	return  0;
+}
+
+/**
+ * @brief 		-  Fill the TX FIFO  with txcount bytes
+ *  
+ * @param ss_qspi 	- Pointer to the spi_device private data 
+ * @param txcount   - Write FIFO lenght 
+ */
+static void ss_qspi_write_fifo(struct smartsens_qspi *ss_qspi, int txcount)
+{
+	int count, k;
+	u32 config_reg ;
+
+	count = ss_qspi->tx_bytes;
+
+	/* tx inter disable */
+	ss_qspi_intr_switch(ss_qspi->dev, true, false);
+
+	/* wait for tx fifo empty */
+	while((ss_qspi_reads(ss_qspi, SS_QSPI_TX_FREE_OFFSET) & SS_QSPI_TX_FREE_MASK));
+
+	if (count > txcount)
+		count = txcount;
+
+	if (ss_qspi->txbuf) 
+	{
+		/* set threshold & tx len */
+		ss_qspi_set_trans_lens(ss_qspi.dev, count, true);
+
+		for (int i = 0; i < count; i++)
+			ss_qspi_write(ss_qspi, SS_QSPI_TX_DATA_OFFSET , ss_qspi->txbuf[i]);
+		
+		/* start transfer */
+		ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_RESTART);
+		ss_qspi->txbuf += count ;
+		ss_qspi->tx_bytes -= count;
+	} 	
+
+	/* tx inter enable */
+	ss_qspi_intr_switch(ss_qspi->dev, true, true);
+}
+
+/**
+ * @brief 		-  Fill the RX FIFO  with rxcount bytes
+ *  
+ * @param ss_qspi 	- Pointer to the spi_device private data 
+ * @param rxcount   - Read FIFO lenght 
+ */
+static void ss_qspi_read_fifo(struct smartsens_qspi *ss_qspi, int rxcount)
+{
+	int count, k;
+
+	count =	ss_qspi->rx_bytes;
+	
+	/* rx inter disable */
+	ss_qspi_intr_switch(ss_qspi->dev, false, false);
+
+	/* wait for RX fifo  not empty */
+	while(!(ss_qspi_reads(ss_qspi, SS_QSPI_RX_FREE_OFFSET) & SS_QSPI_RX_FREE_MASK));
+
+	if (count > rxcount)
+		count = rxcount;
+
+	if (ss_qspi->rxbuf) {
+		/* set rx threshold & rx len */
+		ss_qspi_set_trans_lens(ss_qspi.dev, count, false);
+
+		for (int i = 0; i < count; i++)
+			ss_qspi->rxbuf[i] = ss_qspi_read(ss_qspi, SS_QSPI_RX_DATA_OFFSET);		
+		/* start transfer */
+		ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_RESTART);
+		ss_qspi->rxbuf += count;
+		ss_qspi->rx_bytes -= count;
+	}
+
+	/* rx inter enable */
+	ss_qspi_intr_switch(ss_qspi->dev, false, true);
+}
+
+static irqreturn_t ss_qspi_tx_irq_hdlr(int irq, void *dev_id)
+{
+	u32 intr_status;
+	struct smartsens_qspi *ss_qspi = (struct smartsens_qspi *)dev_id;
+
+	intr_status = ss_qspi_read(ss_qspi, SS_QSPI_STS_OFFSET);
+	
+	/* check tx interrupt status  */
+	if (intr_status & SS_QSPI_FIFO_STS_TX_INT_MASK) {
+		if (ss_qspi->tx_bytes) {
+			/* There is more data to send */
+			ss_qspi_write_fifo(ss_qspi, DEFAULT_FIFO_DEPTH);
+			
+		} else {			 
+			/* tx inter disable */
+			ss_qspi_intr_switch(ss_qspi->dev, true, false);
+			complete(&ss_qspi->data_completion);
+		}
+		return IRQ_HANDLED;
+	}
+
+	return IRQ_NONE;
+}
+
+static irqreturn_t ss_qspi_rx_irq_hdlr(int irq, void *dev_id)
+{
+	u32 intr_status;
+	struct smartsens_qspi *ss_qspi = (struct smartsens_qspi *)dev_id;
+
+	intr_status = ss_qspi_read(ss_qspi, SS_QSPI_STS_OFFSET);
+
+	if (intr_status & SS_QSPI_FIFO_STS_RX_INT_MASK) {
+		if (ss_qspi->rx_bytes) {
+			/* There is more data to read */
+			ss_qspi_read_fifo(ss_qspi, DEFAULT_FIFO_DEPTH);
+		} else {
+			/* rx inter disable */
+			ss_qspi_intr_switch(ss_qspi->dev, false, false);
+			complete(&ss_qspi->data_completion);
+		}
+		return IRQ_HANDLED;
+	}
+	return IRQ_NONE;
+}
+
+/**
+ * ss_qspi_exec_mem_op() - Initiates the QSPI transfer
+ * @mem: the SPI memory
+ * @op: the memory operation to execute
+ * Executes a memory operation.
+ * Return: 0 in case of success, a negative error code otherwise.
+ */
+static int ss_qspi_exec_mem_op(struct spi_mem *mem,
+				 const struct spi_mem_op *op)
+{
+	struct smartsens_qspi *ss_qspi = 
+		spi_controller_get_devdata(mem->spi->master);
+	int i;
+	u8 *tmpbuf;
+
+	dev_dbg(ss_qspi->dev, "cmd:%#x mode:%d.%d.%d.%d\n",
+		op->cmd.opcode, op->cmd.buswidth, op->addr.buswidth,
+		op->dummy.buswidth, op->data.buswidth);
+
+	/* send cmd */	
+	if (op->cmd.opcode) {
+		reinit_completion(&ss_qspi->data_completion);
+		ss_qspi->txbuf = (u8 *)&op->cmd.opcode;
+		ss_qspi->rxbuf = NULL;
+		ss_qspi->tx_bytes = op->cmd.nbytes;
+		ss_qspi->rx_bytes = 0;
+		
+		/* tx inter enable */
+		ss_qspi_intr_switch(ss_qspi->dev, true, true);
+		ss_qspi_write_fifo(ss_qspi, DEFAULT_FIFO_DEPTH);	
+
+		if (!wait_for_completion_timeout(&ss_qspi->data_completion,
+									msecs_to_jiffies(1000)))
+		{
+			ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_DONE);
+			return -ETIMEDOUT;
+		}
+	}
+	/* send addr */
+	if (op->addr.nbytes) {
+		for (i = 0; i < op->addr.nbytes; i++) {
+			ss_qspi->txbuf[i] = op->addr.val >>
+					(8 * (op->addr.nbytes - i - 1));
+		}
+		reinit_completion(&ss_qspi->data_completion);
+		ss_qspi->rxbuf = NULL;
+		ss_qspi->tx_bytes = op->addr.nbytes;
+		ss_qspi->rx_bytes = 0;
+		
+		/* tx inter enable */
+		ss_qspi_intr_switch(ss_qspi->dev, true, true);
+		ss_qspi_write_fifo(ss_qspi, DEFAULT_FIFO_DEPTH);
+
+		if (!wait_for_completion_timeout(&ss_qspi->data_completion,
+								msecs_to_jiffies(1000)))
+		{
+			ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_DONE);
+			return -ETIMEDOUT;
+		}
+	}
+	/* send dummy */
+	if (op->dummy.nbytes) {
+		tmpbuf = kzalloc(op->dummy.nbytes, GFP_KERNEL);
+		memset(tmpbuf, 0xff, op->dummy.nbytes);
+		reinit_completion(&ss_qspi->data_completion);
+		ss_qspi->txbuf = tmpbuf;
+		ss_qspi->rxbuf = NULL;
+		ss_qspi->tx_bytes = op->dummy.nbytes;
+		ss_qspi->rx_bytes = 0;
+		
+		/* tx inter enable */
+		ss_qspi_intr_switch(ss_qspi->dev, true, true);
+		ss_qspi_write_fifo(ss_qspi, DEFAULT_FIFO_DEPTH);
+
+		if (!wait_for_completion_timeout(&ss_qspi->data_completion,
+								msecs_to_jiffies(1000)))
+		{
+			kfree(tmpbuf);
+			ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_DONE);
+			return -ETIMEDOUT;
+		}
+	
+		kfree(tmpbuf);
+	}
+	/* write or read data  */
+	if (op->data.nbytes) {
+		reinit_completion(&ss_qspi->data_completion);
+		if (op->data.dir == SPI_MEM_DATA_OUT) {
+			ss_qspi->txbuf = (u8 *)op->data.buf.out;
+			ss_qspi->tx_bytes = op->data.nbytes;
+			ss_qspi->rxbuf = NULL;
+			ss_qspi->rx_bytes = op->data.nbytes;
+		} else {
+			ss_qspi->txbuf = NULL;
+			ss_qspi->rxbuf = (u8 *)op->data.buf.in;
+			ss_qspi->rx_bytes = op->data.nbytes;
+			ss_qspi->tx_bytes = op->data.nbytes;
+		}
+
+		/* tx inter enable */
+		ss_qspi_intr_switch(ss_qspi->dev, false, true);
+		ss_qspi_read_fifo(ss_qspi, DEFAULT_FIFO_DEPTH);	
+
+		if (!wait_for_completion_timeout(&ss_qspi->data_completion,
+							       msecs_to_jiffies(1000)))
+		{
+			ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_DONE);		
+			return -ETIMEDOUT;
+		}
+	}
+	
+	ss_qspi_trans_ctl(ss_qspi->dev, TRANS_CTL_DONE);
+	
+	return 0;
+}
+
+
+
+static const struct spi_controller_mem_ops ss_qspi_mem_ops = {
+	.supports_op = ss_qspi_supports_op,
+	.exec_op = ss_qspi_exec_mem_op,
+};
+
+
+static int ss_qspi_probe(struct platform_device *pdev)
+{
+	int ret = 0 ;
+	struct spi_controller *ctlr;
+	struct device *dev = &pdev->dev;
+	struct device_node *np = dev->of_node;
+	struct smartsens_qspi *ss_qspi;
+	u32 num_cs;
+
+	ctlr = spi_alloc_master(&pdev->dev , sizeof(ss_qspi));
+	if(!ctlr)
+		return -ENOMEM;
+	
+	ss_qspi = spi_controller_get_devdata(ctlr);
+	ss_qspi->dev = dev;
+	platform_set_drvdata(pdev, ss_qspi);
+	ss_qspi->regs = devm_platform_get_and_ioremap_resource(pdev, 0);
+	
+	if (IS_ERR(ss_qspi->regs)) {
+		ret = PTR_ERR(ss_qspi->regs);
+		goto remove_master;
+	}
+
+	init_completion(&ss_qspi->data_completion);
+	
+
+	/* request tx irq */	
+	ss_qspi->tx_irq = platform_get_irq(pdev, 0);
+	if (ss_qspi->tx_irq <= 0) {
+		ret = -ENXIO;
+		goto remove_master;
+	}
+	ret = devm_request_irq(&pdev->dev, ss_qspi->tx_irq, ss_qspi_tx_irq_hdlr,
+			       0, pdev->name, ss_qspi);
+	if (ret != 0) {
+		ret = -ENXIO;
+		dev_err(&pdev->dev, "request_irq failed\n");
+		goto remove_master;
+	}
+	
+	/* request rx irq */	
+	ss_qspi->rx_irq = platform_get_irq(pdev, 1);
+	if (ss_qspi->rx_irq <= 0) {
+		ret = -ENXIO;
+		goto remove_master;
+	}
+	ret = devm_request_irq(&pdev->dev, ss_qspi->rx_irq, ss_qspi_rx_irq_hdlr,
+			       0, pdev->name, ss_qspi);
+	if (ret != 0) {
+		ret = -ENXIO;
+		dev_err(&pdev->dev, "request_irq failed\n");
+		goto remove_master;
+	}
+
+	ret = of_property_read_u32(&np, "num-cs", &num_cs);
+	if(ret < 0){
+		ctlr->num_chipselect = 1 ;
+	}else if (num_cs > SS_QSPI_MAX_CS_NUM){
+		ret = -EINVAL;
+		dev_err(&pdev->dev,"only 1 chip selects are available\n");
+	}else{
+		ctlr->num_chipselect = num_cs;
+	}
+
+	ctlr->mode_bits = SPI_RX_DUAL | SPI_RX_QUAD |
+			    SPI_TX_DUAL | SPI_TX_QUAD;
+	ctlr->mem_ops = &ss_qspi_mem_ops;
+	ctlr->setup = ss_qspi_setup_op;
+	// ctlr->max_speed_hz = clk_get_rate(ss_qspi->refclk) / 2;
+	// ctlr->max_speed_hz = SS_QSPI_MAX_CLK; 
+	ctlr->dev.of_node = np;
+
+	ss_qspi_init_hw(ss_qspi, ctlr->num_chipselect);
+
+	ret = devm_spi_register_controller(&pdev->dev, ctlr);
+	if (ret) {
+		dev_err(&pdev->dev, "spi_register_master failed\n");
+		goto remove_master;
+	}
+
+	return ret;
+
+remove_master:
+	spi_controller_put(ctlr);
+	return ret;
+}
+
+
+/**
+ * ss_qspi_remove - Remove method for the QSPI driver
+ * This function is called if a device is physically removed from the system or
+ * if the driver module is being unloaded. It frees all resources allocated to
+ * the device.
+ */
+static int ss_qspi_remove(struct platform_device *pdev)
+{
+	struct smartsens_qspi *ss_qspi = platform_get_drvdata(pdev);
+
+	ss_qspi_write(ss_qspi, SS_QSPI_GLBCFG_EN_MASK, 0);
+
+	return 0;
+}
+
+
+static const struct of_device_id ss_qspi_of_match[] = {
+	{ .compatible = "SmartSens,spi-1.0", },
+	{ /* end of table */ }
+};
+
+MODULE_DEVICE_TABLE(of, ss_qspi_of_match);
+
+/*
+ * ss_qspi_driver - This structure defines the QSPI platform driver
+ */
+static struct platform_driver ss_qspi_driver = {
+	.probe = ss_qspi_probe,
+	.remove = ss_qspi_remove,
+	.driver = {
+		.name = "ss-qspi",
+		.of_match_table = ss_qspi_of_match,
+	},
+};
+
+module_platform_driver(ss_qspi_driver);
+
+MODULE_AUTHOR("SmartSens, Inc.");
+MODULE_DESCRIPTION("SmartSens S1 QSPI driver");
+MODULE_LICENSE("GPL");
