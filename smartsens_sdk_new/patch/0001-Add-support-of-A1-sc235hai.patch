diff --git a/arch/arm/boot/dts/smartsens-m1-evb.dts b/arch/arm/boot/dts/smartsens-m1-evb.dts
new file mode 100644
index 000000000..8026d0701
--- /dev/null
+++ b/arch/arm/boot/dts/smartsens-m1-evb.dts
@@ -0,0 +1,67 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+
+/*
+ * Device Tree Include file for SmartSensTech M family SoC
+ *
+ * Copyright (C) 2022-2024 SmartSensTech Ltd.
+ *
+ * Author: Zhang Jie <jie.zhang@smartsenstech.com>
+ * 
+ */
+
+/dts-v1/;
+
+#include "smartsens-m1.dtsi"
+
+/ {
+	model = "Smartsens M1 SOC Evaluation Board";
+	compatible = "smartsens,m1-evb";
+
+	chosen {
+		/* stdout-path = "serial2:1500000n8"; */
+		bootargs = "earlyprintk loglevel=8 rdinit=/sbin/init";
+		stdout-path = &uart0;
+	};
+
+	aliases {
+	};
+
+	timer {
+		compatible = "arm,armv7-timer";
+		interrupts = <GIC_PPI 13 (GIC_CPU_MASK_SIMPLE(1) | IRQ_TYPE_LEVEL_HIGH)>,
+			     <GIC_PPI 14 (GIC_CPU_MASK_SIMPLE(1) | IRQ_TYPE_LEVEL_HIGH)>;
+		clock-frequency = <12000000>;
+	};
+
+	memory@00000000 {
+		device_type = "memory";
+		/* 64MB ram */
+		reg = <0x00000000 0x08000000>;
+	};
+
+	reserved-memory {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		ranges;
+
+		osd_cma {
+			compatible = "shared-dma-pool";
+			reusable;
+			reg = <0x05800000 0x00400000>; /* 4M */
+		};
+
+		ai_cma {
+			compatible = "shared-dma-pool";
+			/* no-map; */
+			reusable;
+			reg = <0x05c00000 0x02400000>; /* 36M */
+		};
+	};
+};
+
+&uart0 {
+	clock-frequency = <300000000>;
+	current-speed = <115200>;
+	status = "okay";
+};
+
diff --git a/arch/arm/boot/dts/smartsens-m1-fpga.dts b/arch/arm/boot/dts/smartsens-m1-fpga.dts
new file mode 100644
index 000000000..965544411
--- /dev/null
+++ b/arch/arm/boot/dts/smartsens-m1-fpga.dts
@@ -0,0 +1,77 @@
+// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
+
+/dts-v1/;
+
+#include "smartsens-m1.dtsi"
+
+/ {
+	model = "Smartsens M1 SoC FPGA board";
+	compatible = "smartsens,m1-fpga";
+
+	chosen {
+		/* stdout-path = "serial2:1500000n8"; */
+        bootargs = "earlyprintk earlycon loglevel=8 console=ttyS0 rdinit=/sbin/init";
+        stdout-path = &uart0;
+	};
+
+	timer {
+		compatible = "arm,armv7-timer";
+		interrupts = <GIC_PPI 13 (GIC_CPU_MASK_SIMPLE(1) | IRQ_TYPE_LEVEL_HIGH)>,
+			     <GIC_PPI 14 (GIC_CPU_MASK_SIMPLE(1) | IRQ_TYPE_LEVEL_HIGH)>;
+		clock-frequency = <1000000>;
+	};
+
+	memory@00000000 {
+		device_type = "memory";
+    /* 128MB ram */
+		reg = <0x00000000 0x08000000>;
+	};
+
+  reserved-memory {
+    #address-cells = <1>;
+    #size-cells = <1>;
+    ranges;
+
+#if 0
+    osd_cma {
+      compatible = "shared-dma-pool";
+      reusable;
+      reg = <0x01800000 0x00800000>;
+    };
+
+    media_cma {
+      compatible = "shared-dma-pool";
+      reusable;
+      reg = <0x02000000 0x02000000>; /* 32M */
+      linux,cma-default;
+    };
+#else
+/*
+    debug_cma {
+      compatible = "shared-dma-pool";
+      reusable;
+      size = <0x03000000 0x00800000>;
+      linux,cma-default;
+    };
+*/
+    osd_cma {
+      compatible = "shared-dma-pool";
+      reusable;
+      reg = <0x03800000 0x00800000>;
+    };
+#endif
+
+    ai_cma {
+      compatible = "shared-dma-pool";
+      /* no-map; */
+      reusable;
+      reg = <0x04000000 0x04000000>; /* 64M */
+    };
+  };
+};
+
+&uart0 {
+	clock-frequency = <25000000>;
+	current-speed = <115200>;
+	status = "okay";
+};
diff --git a/arch/arm/boot/dts/smartsens-m1.dtsi b/arch/arm/boot/dts/smartsens-m1.dtsi
