+
+static irqreturn_t smarts1_interrupt(int irq, void *dev_id)
+{
+	struct uart_port *port = dev_id;
+	unsigned long flags;
+	u32 stat;
+	u32 val = 0;
+
+	spin_lock_irqsave(&port->lock, flags);
+
+	stat = smarts1_uart_read(port, SMARTS1_REG_RX_STATUS_OFFSET);
+
+    if(stat & SMARTS1_UART_RX_TIMEOUT_ERR)
+    {
+        /* clr rx timeout status */
+        val |= SMARTS1_CLR_RX_TIMEOUT_ERR;
+        smarts1_uart_write(port, val, SMARTS1_REG_RX_IRQ_CLR_OFFSET);
+        val &= ~(SMARTS1_CLR_RX_TIMEOUT_ERR);
+        smarts1_uart_write(port, val, SMARTS1_REG_RX_IRQ_CLR_OFFSET);
+    }
+
+    smarts1_uart_receive_chars(port);
+
+	spin_unlock_irqrestore(&port->lock, flags);
+
+	return IRQ_HANDLED;
+}
+
+static int smarts1_uart_startup(struct uart_port *port)
+{
+	unsigned long flags;
+	int ret;
+	u32 val;
+
+	spin_lock_irqsave(&port->lock, flags);
+    /* disable rx & rx IRQs */
+	smarts1_uart_write(port, 0, SMARTS1_REG_RX_CTRL_OFFSET);
+	spin_unlock_irqrestore(&port->lock, flags);
+
+    /* rx interrupt */
+	ret = request_irq(port->irq, smarts1_interrupt, IRQF_TRIGGER_NONE,
+			  "smarts1-uart", port);
+	if (ret)
+		return ret;
+
+	spin_lock_irqsave(&port->lock, flags);
+
+    /* disable tx interrupt */
+	val = smarts1_uart_read(port, SMARTS1_REG_TX_IRQ_EN_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 0, 1, 0x0);
+	smarts1_uart_write(port, val, SMARTS1_REG_TX_IRQ_EN_OFFSET);
+
+	/* tx baud, on fpga set to 217 */
+	val = port->uartclk / smarts1_uart_ports[port->line]->baud;
+	smarts1_uart_write(port, val, SMARTS1_REG_TX_BAUD_OFFSET);
+
+	/* enble tx, disable tx parity */
+	val = smarts1_uart_read(port, SMARTS1_REG_TX_CTRL_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 0, 2, 0x1);
+	smarts1_uart_write(port, val, SMARTS1_REG_TX_CTRL_OFFSET);
+
+	/* rx baud, on fpga set to 217 */
+	val = port->uartclk / smarts1_uart_ports[port->line]->baud;
+	smarts1_uart_write(port, val, SMARTS1_REG_RX_BAUD_OFFSET);
+
+	/* enable rx */
+    val = smarts1_uart_read(port, SMARTS1_REG_RX_CTRL_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val, 16, 16, 0x1); /* rx enable */
+	SMARTS1_VAL_MODIFY_FIELD(val, 8, 13, 0x0); /* rx threshold, set non 0 to enalbe rx interrupt */
+	SMARTS1_VAL_MODIFY_FIELD(val,  0, 7, 0xff); /* rx timeout val */
+	smarts1_uart_write(port, val, SMARTS1_REG_RX_CTRL_OFFSET);
+
+	/* enable rx interrupt */
+    val = smarts1_uart_read(port, SMARTS1_REG_RX_IRQ_EN_OFFSET);
+	SMARTS1_VAL_MODIFY_FIELD(val,  1, 1, 0x1); /* rx timeout interrupt enable */
+	smarts1_uart_write(port, val, SMARTS1_REG_RX_IRQ_EN_OFFSET);
+
+	spin_unlock_irqrestore(&port->lock, flags);
+
+	return 0;
+}
+
+static void smarts1_uart_shutdown(struct uart_port *port)
+{
+	unsigned long flags;
+
+	spin_lock_irqsave(&port->lock, flags);
+
+	smarts1_uart_stop_tx(port);
+	smarts1_uart_stop_rx(port);
+
+	spin_unlock_irqrestore(&port->lock, flags);
+}
+
+static const char *smarts1_uart_type(struct uart_port *port)
+{
+	return (port->type == PORT_SMARTS1) ? "smarts1-uart" : NULL;
+}
+
+static int smarts1_uart_request_port(struct uart_port *port)
+{
+	struct platform_device *pdev = to_platform_device(port->dev);
+	struct resource *res;
+
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (!res)
+    {
+        printk("%s[%d]\n",__func__, __LINE__);
+		return -ENXIO;
+    }
+
+	if (!devm_request_mem_region(port->dev, port->mapbase,
+				     resource_size(res), dev_name(port->dev)))
+    {
+        printk("%s[%d]\n",__func__, __LINE__);
+		return -EBUSY;
+    }
+
+	if (port->flags & UPF_IOREMAP) {
+		port->membase = devm_ioremap(port->dev, port->mapbase,
+						     resource_size(res));
+		if (!port->membase)
+		{
+			printk("%s[%d]\n",__func__, __LINE__);
+			return -EBUSY;
+		}
+	}
+
+	return 0;
+}
+
+static void smarts1_uart_config_port(struct uart_port *port, int flags)
+{
+	unsigned long irq_flags;
+
+	if (flags & UART_CONFIG_TYPE) {
+		port->type = PORT_SMARTS1;
+		smarts1_uart_request_port(port);
+	}
+
+	spin_lock_irqsave(&port->lock, irq_flags);
+
+	/* Clear mask, so no surprise interrupts.
+	 * bit[3:0], pulse signal to clear rx status register */
+	smarts1_uart_write(port, 0xf, SMARTS1_REG_RX_IRQ_CLR_OFFSET);
+	smarts1_uart_write(port, 0x0, SMARTS1_REG_RX_IRQ_CLR_OFFSET);
+
+	spin_unlock_irqrestore(&port->lock, irq_flags);
+}
+
+static void smarts1_uart_release_port(struct uart_port *port)
+{
+	struct platform_device *pdev = to_platform_device(port->dev);
+	struct resource *res;
+
+	res = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (!res)
+		return;
+
+	if (port->flags & UPF_IOREMAP) {
+		devm_release_mem_region(port->dev, port->mapbase,
+					resource_size(res));
+		devm_iounmap(port->dev, port->membase);
+		port->membase = NULL;
+	}
+}
+
+static int smarts1_uart_verify_port(struct uart_port *port,
+				struct serial_struct *ser)
+{
+	if (port->type != PORT_SMARTS1)
+		return -EINVAL;
+
+	if (port->irq != ser->irq)
+		return -EINVAL;
+
+	return 0;
+}
+
+static const struct uart_ops smarts1_uart_ops = {
+	.tx_empty       = smarts1_uart_tx_empty,
+	.get_mctrl      = smarts1_uart_get_mctrl,
+	.set_mctrl      = smarts1_uart_set_mctrl,
+	.start_tx       = smarts1_uart_start_tx,
+	.stop_tx        = smarts1_uart_stop_tx,
+	.stop_rx        = smarts1_uart_stop_rx,
+	.startup        = smarts1_uart_startup,
+	.shutdown       = smarts1_uart_shutdown,
+	.set_termios    = smarts1_uart_set_termios,
+	.type           = smarts1_uart_type,
+	.request_port	= smarts1_uart_request_port,
+	.release_port	= smarts1_uart_release_port,
+	.config_port	= smarts1_uart_config_port,
+	.verify_port	= smarts1_uart_verify_port,
+};
+
+#ifdef CONFIG_SERIAL_SMARTS1_CONSOLE
+static void smarts1_uart_port_write(struct uart_port *port, const char *s,
+				u_int count)
+{
+	unsigned long flags;
+	int locked;
+
+	local_irq_save(flags);
+
+	if (port->sysrq) {
+		locked = 0;
+	} else if (oops_in_progress) {
+		locked = spin_trylock(&port->lock);
+	} else {
+		spin_lock(&port->lock);
+		locked = 1;
+	}
+
+	uart_console_write(port, s, count, smarts1_putchar);
+
+	if (locked)
+		spin_unlock(&port->lock);
+
+	local_irq_restore(flags);
+}
+
+static void smarts1_uart_console_write(struct console *co, const char *s,
+				   u_int count)
+{
+	struct smarts1_uart_port *smarts1_port;
+
+	smarts1_port = smarts1_uart_ports[co->index];
+	if (!smarts1_port)
+		return;
+
+	smarts1_uart_port_write(&smarts1_port->port, s, count);
+}
+
+static int smarts1_uart_console_setup(struct console *co, char *options)
+{
+	struct smarts1_uart_port *smarts1_port;
+	int baud = 115200;
+	int bits = 8;
+	int parity = 'n';
+	int flow = 'n';
+
+	if (co->index < 0 || co->index >= SMARTS1_UART_PORT_NUM)
+		return -EINVAL;
+
+	smarts1_port = smarts1_uart_ports[co->index];
+	if (!smarts1_port || !smarts1_port->port.membase)
+		return -ENODEV;
+
+	baud = smarts1_port->baud;
+	if (options)
+		uart_parse_options(options, &baud, &parity, &bits, &flow);
+
+	return uart_set_options(&smarts1_port->port, co, baud, parity, bits, flow);
+}
+
+static struct console smarts1_uart_console = {
+	.name = SMARTS1_UART_DEV_NAME,
+	.write = smarts1_uart_console_write,
+	.device = uart_console_device,
+	.setup = smarts1_uart_console_setup,
+	.flags = CON_PRINTBUFFER,
+	.index = -1,
+	.data = &smarts1_uart_driver,
+};
+
+static int __init smarts1_uart_console_init(void)
+{
+	register_console(&smarts1_uart_console);
+
+	return 0;
+}
+console_initcall(smarts1_uart_console_init);
+
+static void smarts1_uart_early_console_write(struct console *co,
+					 const char *s,
+					 u_int count)
+{
+	struct earlycon_device *dev = co->data;
+
+	smarts1_uart_port_write(&dev->port, s, count);
+}
+
+static int __init
+smarts1_uart_early_console_setup(struct earlycon_device *device, const char *opt)
+{
+	if (!device->port.membase)
+		return -ENODEV;
+
+	device->con->write = smarts1_uart_early_console_write;
+
+	return 0;
+}
+
+OF_EARLYCON_DECLARE(smarts1, "smartsens,s1-uart",
+		    smarts1_uart_early_console_setup);
+
+#define SMARTS1_UART_CONSOLE (&smarts1_uart_console)
+#else
+#define SMARTS1_UART_CONSOLE NULL
+#endif /* CONFIG_SERIAL_SMARTS1_CONSOLE */
+
+static struct uart_driver smarts1_uart_driver = {
+	.owner = THIS_MODULE,
+	.driver_name = "smarts1-uart",
+	.dev_name = SMARTS1_UART_DEV_NAME,
+	.nr = SMARTS1_UART_PORT_NUM,
+	.cons = SMARTS1_UART_CONSOLE,
+};
+
+static const struct of_device_id smarts1_uart_dt_matches[] = {
+	{ .compatible = "smartsens,s1-uart" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, smarts1_uart_dt_matches);
+
+static int smarts1_uart_probe(struct platform_device *pdev)
+{
+	struct resource *res_mem;
+	struct smarts1_uart_port *smarts1_port;
+	int ret, irq;
+
+	if (pdev->dev.of_node)
+		pdev->id = of_alias_get_id(pdev->dev.of_node, "serial");
+
+	if (pdev->id < 0 || pdev->id >= SMARTS1_UART_PORT_NUM) {
+		dev_err(&pdev->dev, "id %d out of range\n", pdev->id);
+		return -EINVAL;
+	}
+
+	res_mem = platform_get_resource(pdev, IORESOURCE_MEM, 0);
+	if (!res_mem) {
+		dev_err(&pdev->dev, "could not get mem\n");
+		return -ENODEV;
+	}
+
+	irq = platform_get_irq(pdev, 0);
+	if (irq < 0)
+		return irq;
+
+	if (smarts1_uart_ports[pdev->id]) {
+		dev_err(&pdev->dev, "port %d already allocated\n", pdev->id);
+		return -EBUSY;
+	}
+
+	smarts1_port = devm_kzalloc(&pdev->dev, sizeof(struct smarts1_uart_port), GFP_KERNEL);
+	if (!smarts1_port)
+		return -ENOMEM;
+
+	smarts1_port->port.dev = &pdev->dev;
+	smarts1_port->port.regshift = 0;
+	smarts1_port->port.line = pdev->id;
+	smarts1_port->port.type = PORT_SMARTS1;
+	smarts1_port->port.iotype = UPIO_MEM;
+	smarts1_port->port.mapbase = res_mem->start;
+	smarts1_port->port.irq = irq;
+	smarts1_port->port.flags = UPF_BOOT_AUTOCONF | UPF_IOREMAP;
+	smarts1_port->port.x_char = 0;
+	smarts1_port->port.fifosize = SMARTS1_UART_TX_FIFO_SIZE;
+	smarts1_port->port.ops = &smarts1_uart_ops;
+
+	if (of_property_read_u32(pdev->dev.of_node, "clock-frequency", &smarts1_port->port.uartclk)) {
+		dev_err(&pdev->dev, "clock-frequency property NOT set\n");
+		return -EINVAL;
+	}
+
+	if (of_property_read_u32(pdev->dev.of_node, "current-speed", &smarts1_port->baud)) {
+		dev_err(&pdev->dev, "current-speed property NOT set\n");
+		return -EINVAL;
+	}
+	smarts1_uart_ports[pdev->id] = smarts1_port;
+	platform_set_drvdata(pdev, smarts1_port);
+
+	ret = uart_add_one_port(&smarts1_uart_driver, &smarts1_port->port);
+	if (ret)
+    {
+        printk("smarts1 uart add one port fail\n");
+		smarts1_uart_ports[pdev->id] = NULL;
+    }
+
+	return ret;
+}
+
+static int smarts1_uart_remove(struct platform_device *pdev)
+{
+	struct smarts1_uart_port *smarts1_port = platform_get_drvdata(pdev);
+
+	uart_remove_one_port(&smarts1_uart_driver, &smarts1_port->port);
+	smarts1_uart_ports[pdev->id] = NULL;
+
+	return 0;
+}
+
+static struct platform_driver smarts1_uart_platform_driver = {
+	.probe = smarts1_uart_probe,
+	.remove = smarts1_uart_remove,
+	.driver = {
+		.name = "smarts1-uart",
+		.of_match_table = smarts1_uart_dt_matches,
+	},
+};
+
+static int __init smarts1_uart_init(void)
+{
+	int ret;
+
+	ret = uart_register_driver(&smarts1_uart_driver);
+	if (ret)
+		return ret;
+
+	ret = platform_driver_register(&smarts1_uart_platform_driver);
+	if (ret)
+		uart_unregister_driver(&smarts1_uart_driver);
+
+	return ret;
+}
+
+static void __exit smarts1_uart_exit(void)
+{
+	platform_driver_unregister(&smarts1_uart_platform_driver);
+	uart_unregister_driver(&smarts1_uart_driver);
+}
+
+module_init(smarts1_uart_init);
+module_exit(smarts1_uart_exit);
+
+MODULE_AUTHOR("wangwei @smartsens");
+MODULE_DESCRIPTION("smartsens s1 serial device driver");
+MODULE_LICENSE("GPL");
