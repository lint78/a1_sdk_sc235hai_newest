+#ifndef _SMARTS1_UART_H_
+#define _SMARTS1_UART_H_
+
+#include <asm/io.h>
+
+#define SMARTS1_REG_OFFSET(type, mem) ((unsigned int)&(((type *)0)->mem))
+
+#define SMARTS1_REG_RX_BAUD_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_baud_div)
+#define SMARTS1_REG_RX_CTRL_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_ctrl)
+#define SMARTS1_REG_RX_IRQ_EN_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_irq_en)
+#define SMARTS1_REG_RX_IRQ_CLR_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_irq_clr)
+#define SMARTS1_REG_RX_STATUS_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_status)
+#define SMARTS1_REG_RX_FIFO_REMAIN_CNT_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_fifo_remain_cnt)
+#define SMARTS1_REG_RX_DATA_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_data)
+#define SMARTS1_REG_RX_RESET_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_rx_reset)
+#define SMARTS1_REG_TX_BAUD_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_baud_div)
+#define SMARTS1_REG_TX_CTRL_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_ctrl)
+#define SMARTS1_REG_TX_IRQ_EN_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_irq_en)
+#define SMARTS1_REG_TX_IRQ_CLR_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_irq_clr)
+#define SMARTS1_REG_TX_STATUS_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_status)
+#define SMARTS1_REG_TX_DATA_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_data)
+#define SMARTS1_REG_TX_RESET_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_reset)
+#define SMARTS1_REG_TX_FIFO_FREE_CNT_OFFSET SMARTS1_REG_OFFSET(struct smarts1_uart_reg, reg_tx_fifo_free_cnt)
+
+#define SMARTS1_CLR_RX_TIMEOUT_ERR   (0x1 << 1)
+#define SMARTS1_CLR_STOP_SIG_ERR     (0x1 << 0)
+#define SMARTS1_CLR_PARITY_FAIL_ERR  (0x1 << 2)
+#define SMARTS1_CLR_RX_FIFO_FULL_ERR (0x1 << 3)
+#define SMARTS1_EN_STOP_SIG_IRQ      (0x1 << 4)
+#define SMARTS1_EN_RX_TIMEOUT_IRQ    (0x1 << 5)
+#define SMARTS1_EN_PARITY_FAIL_IRQ   (0x1 << 6)
+#define SMARTS1_EN_RX_FIFO_FULL_IRQ  (0x1 << 7)
+#define	SMARTS1_UART_RX_OVERFLOW_ERR 	(0x1u << 4)
+#define SMARTS1_UART_RX_PARITY_ERR   	(0x1u << 3)
+#define SMARTS1_UART_RX_TIMEOUT_ERR  	(0x1u << 2)
+#define SMARTS1_UART_RX_FRAMING_ERR  	(0x1u << 1)
+#define SMARTS1_UART_RX_DATA_AVAILABLE  (0x1u << 0)
+
+typedef struct smarts1_uart_reg {
+  /* uart rx */
+  /* 0x00 */ volatile unsigned int reg_rx_baud_div;
+  /* 0x04 */ volatile unsigned int reg_rx_ctrl;
+  /* 0x08 */ volatile unsigned int reg_rx_irq_en;
+  /* 0x0c */ volatile unsigned int reg_rx_irq_clr;
